// Prisma schema for Cognal (PostgreSQL).
// Models: User, UserApiKey, Book, Chapter, ReadingProgress, Translation, SavedTranslation.

generator client {
  provider = "prisma-client-js"
  // `native` resolves to the engine for whatever platform runs `prisma generate`
  // — the dev host locally and the linux container in Docker (generated in the
  // same image it runs in), so no extra targets are needed for web deployment.
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  // Bcrypt hash for email/password (Credentials) sign-in. Null for users who
  // only authenticate via an OAuth provider (e.g. Google).
  passwordHash  String?
  name          String?
  // Auth.js standard fields (populated for OAuth users).
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  books             Book[]
  progress          ReadingProgress[]
  savedTranslations SavedTranslation[]
  apiKeys           UserApiKey[]

  @@map("users")
}

// ───────────────────────── Auth.js (NextAuth) models ─────────────────────────
// Managed by @auth/prisma-adapter. Account holds linked OAuth providers; Session
// is required by the adapter even though we use the JWT session strategy;
// VerificationToken backs email verification / magic links if enabled later.

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// A user's own API key for an AI platform (OpenAI, Anthropic, Gemini, …). The
// key is encrypted at the application layer before being stored here; only the
// ciphertext lives in the DB. A user may keep SEVERAL keys per provider — they
// are rotated at translation time to multiply free-tier rate limits.
model UserApiKey {
  id           String   @id @default(uuid())
  userId       String
  // Provider id, e.g. "openai" | "anthropic" | "gemini" | "deepseek" | "groq"
  provider     String
  // AES-256-GCM ciphertext, format "iv:authTag:ciphertext" (hex)
  encryptedKey String
  // Optional model override; falls back to the provider default when null
  model        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, provider])
  @@map("user_api_keys")
}

model Book {
  id        String   @id @default(uuid())
  userId    String
  title     String
  author    String?
  language  String?
  // Source format of the book: "epub" or "pdf". Drives which reader the
  // frontend mounts and the Content-Type used when serving the raw file.
  format    String   @default("epub")
  // Path on disk (inside UPLOAD_DIR) to the stored book file (.epub / .pdf)
  filePath  String
  fileSize  Int
  // Path on disk to the extracted cover image, if any
  coverPath String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters          Chapter[]
  progress          ReadingProgress[]
  savedTranslations SavedTranslation[]

  @@index([userId])
  @@map("books")
}

model Chapter {
  id     String @id @default(uuid())
  bookId String
  label  String
  // href into the epub spine (e.g. "OEBPS/chapter1.xhtml")
  href   String
  order  Int

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("chapters")
}

model ReadingProgress {
  id           String   @id @default(uuid())
  userId       String
  bookId       String
  cfi          String
  percentage   Float    @default(0)
  chapterLabel String?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  // One progress row per (user, book)
  @@unique([userId, bookId])
  @@index([userId])
  @@map("reading_progress")
}

model Translation {
  id             String   @id @default(uuid())
  // SHA256(sourceText + ':' + targetLang)
  hash           String   @unique
  sourceText     String
  translatedText String
  targetLang     String
  createdAt      DateTime @default(now())

  @@index([targetLang])
  @@map("translations")
}

// Append-only stream of product events for the admin analytics dashboard
// (daily traffic, active users, feature usage, top AI providers). Intentionally
// denormalised + decoupled from the user FK (userId is nullable and NOT a
// relation) so writes are cheap and never block/break a request, and rows
// survive user deletion for historical aggregates.
model AnalyticsEvent {
  id        String   @id @default(uuid())
  // Null for anonymous events (e.g. a failed login before a user is known).
  userId    String?
  // Event type, e.g. "login" | "signup" | "upload" | "translate" | "discuss".
  type      String
  // Free-form context, e.g. { provider, targetLang, bookId, format, cached }.
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
  @@index([userId])
  @@map("analytics_events")
}

// User-submitted product feedback, shown to admins in the dashboard. The
// sender's email is captured (from their session) so admins can follow up.
// `userId` is kept (nullable, no relation) so feedback survives user deletion.
model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resolved, createdAt])
  @@map("feedback")
}

// A translation the user saved against a specific location in a book. Powers
// the in-reader highlights and "load from DB instead of asking the AI" flow.
// `Translation` remains the global content cache; this is per-user/per-book.
model SavedTranslation {
  id             String   @id @default(uuid())
  userId         String
  bookId         String
  // EPUB CFI range of the highlighted selection (stable for a given file)
  cfiRange       String
  sourceText     String
  translatedText String
  targetLang     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  // One saved translation per exact location per user.
  @@unique([userId, bookId, cfiRange])
  @@index([userId, bookId])
  @@map("saved_translations")
}
