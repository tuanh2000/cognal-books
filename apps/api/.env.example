# Local-only desktop app config.
# DATABASE_URL is built at runtime from READER_DATA_DIR (file:${READER_DATA_DIR}/reader.db)
# and does not need to be set here. Set it only for standalone prisma CLI usage:
# DATABASE_URL=file:./dev.db
#
# Data directory (Electron passes app.getPath('userData')). Defaults to
# <cwd>/.reader-data when unset.
# READER_DATA_DIR=
API_PORT=4317
# Uploads default to ${READER_DATA_DIR}/uploads; override only if needed.
# UPLOAD_DIR=
# Secret used to AES-256-GCM encrypt user-supplied AI provider keys before they
# are stored in SQLite. REQUIRED for "Add API key" to work. In the packaged
# desktop app Electron generates & injects this automatically (persisted at
# ${READER_DATA_DIR}/.encryption-key); set it here only for standalone/dev runs.
APP_ENCRYPTION_KEY=dev-only-change-me-to-a-random-32-char-string
MAX_UPLOAD_MB=50
# Translation providers (tried in order; falls back on failure). Enable one by
# setting its key. All OpenAI-compatible. See README for free-tier sign-up links.
# Each *_API_KEY accepts multiple comma-separated keys (rotated to raise limits).
TRANSLATION_PROVIDER_ORDER=gemini,groq,openrouter,openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
