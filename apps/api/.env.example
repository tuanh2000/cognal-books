# Cognal API — web deployment config.
#
# PostgreSQL connection string. In Docker Compose the host is the `postgres`
# service name; for local dev point it at your local/containerised Postgres.
DATABASE_URL=postgresql://reader:reader_dev_password@localhost:5432/reader?schema=public

# HTTP server. Binds 0.0.0.0 by default so other containers (nginx) can reach it.
API_PORT=4000
# API_HOST=0.0.0.0
# Comma-separated list of allowed browser origins (CORS). Leave unset in dev to
# allow all; set to your web origin in production, e.g. https://app.cognal.com
# CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Where uploaded books + cover images are stored (a mounted volume in Docker).
# Defaults to <cwd>/.local-data/uploads when unset.
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50

# Secret used to AES-256-GCM encrypt user-supplied AI provider keys before they
# are stored in Postgres. REQUIRED for "Add API key" to work. Use a long random
# value (falls back to JWT_SECRET if unset).
APP_ENCRYPTION_KEY=dev-only-change-me-to-a-random-32-char-string

# Translation providers (tried in order; falls back on failure). Enable one by
# setting its key. All OpenAI-compatible. See README for free-tier sign-up links.
# Each *_API_KEY accepts multiple comma-separated keys (rotated to raise limits).
TRANSLATION_PROVIDER_ORDER=gemini,groq,openrouter,openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
