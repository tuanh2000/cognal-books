# Local (non-docker) development. For docker, the root .env is used instead.
DATABASE_URL=postgresql://reader:reader_dev_password@localhost:5432/reader?schema=public
REDIS_URL=redis://localhost:6379
API_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
# Translation providers (tried in order; falls back on failure). Enable one by
# setting its key. All OpenAI-compatible. See README for free-tier sign-up links.
# Each *_API_KEY accepts multiple comma-separated keys (rotated to raise limits).
TRANSLATION_PROVIDER_ORDER=gemini,groq,openrouter,openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
CORS_ORIGINS=http://localhost:3000
