# Browser-reachable API base URL. For local (non-docker) dev pointing at the
# Nest server directly, use http://localhost:4000/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ── Auth.js (NextAuth) ──────────────────────────────────────
# Postgres connection (same DB as the API) — used by the Prisma adapter and the
# email/password registration route.
DATABASE_URL=postgresql://reader:reader_dev_password@localhost:5432/reader?schema=public

# Secret for Auth.js session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=change_me_run_openssl_rand_base64_32
# Public URL of the web app (required by Auth.js in production).
# AUTH_URL=https://app.cognal.com
# Trust the X-Forwarded-* headers from the nginx reverse proxy (required when the
# app runs behind a proxy, i.e. the Docker deployment).
AUTH_TRUST_HOST=true

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Shared secret used to sign the short-lived HS256 access token the browser sends
# to the NestJS API (Authorization: Bearer). MUST match the API's API_JWT_SECRET.
API_JWT_SECRET=change_me_to_a_long_random_string_shared_with_the_api

# Comma-separated admin emails — gates the /admin analytics dashboard.
ADMIN_EMAILS=htanh9320@gmail.com
