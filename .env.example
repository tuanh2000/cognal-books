# ───────────────────────────────────────────────────────────
# Shared environment for docker-compose. Copy to `.env`.
# ───────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=reader
POSTGRES_PASSWORD=reader_dev_password
POSTGRES_DB=reader

# Connection string used by the API (host `postgres` = compose service name)
DATABASE_URL=postgresql://reader:reader_dev_password@postgres:5432/reader?schema=public

# Redis
REDIS_URL=redis://redis:6379

# API
API_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50

# Secret used to encrypt users' own API keys (AES-256-GCM) before storing them.
# Falls back to JWT_SECRET if unset, but set a dedicated long random value here.
APP_ENCRYPTION_KEY=change_me_to_another_long_random_string

# ── Translation providers ──────────────────────────────────
# The translator tries providers in TRANSLATION_PROVIDER_ORDER and falls back
# to the next when one fails (quota / auth / rate limit / network). A provider
# is ENABLED only when its API key below is set — configure as many as you like.
# All are OpenAI-compatible; defaults are sensible, override models if desired.
#
# Each *_API_KEY may hold MULTIPLE comma-separated keys to multiply free-tier
# rate limits, e.g. GROQ_API_KEY=key1,key2,key3 — requests rotate across them
# (round-robin) and fall through to the next key, then the next provider.
TRANSLATION_PROVIDER_ORDER=gemini,groq,openrouter,openai

# OpenAI (paid). Optional OPENAI_BASE_URL for any OpenAI-compatible endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Anthropic (Claude) — OpenAI-compatible endpoint, https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google Gemini — free tier, get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Groq — free tier, https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — has free models, https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Web (build-time, must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8080/api
