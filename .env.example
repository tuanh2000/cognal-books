# ───────────────────────────────────────────────────────────
# Cognal — shared environment for docker-compose. Copy to `.env`.
# ───────────────────────────────────────────────────────────

# ── Postgres ──
POSTGRES_USER=reader
POSTGRES_PASSWORD=reader_dev_password
POSTGRES_DB=reader
# Connection string used by BOTH the API and the web app (Auth.js Prisma
# adapter). Host `postgres` = the compose service name.
DATABASE_URL=postgresql://reader:reader_dev_password@postgres:5432/reader?schema=public

# ── API ──
API_PORT=4000
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50
# Browser origin(s) allowed to call the API (the public nginx origin).
CORS_ORIGINS=http://localhost:8080
# Free-tier cap: translate+discuss per user per 24h on shared keys (0 = off).
FREE_DAILY_LIMIT=200
# Encrypts users' own AI keys at rest (AES-256-GCM). Use a long random value.
APP_ENCRYPTION_KEY=change_me_to_a_long_random_string

# ── Auth (shared web + API) ──
# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=change_me_run_openssl_rand_base64_32
# Public URL of the app (what the browser hits — nginx). Used by Auth.js.
AUTH_URL=http://localhost:8080
# Signs/verifies the short-lived access token the web app sends to the API.
# The SAME value must be set for both services.
API_JWT_SECRET=change_me_to_another_long_random_string
# Comma-separated admin emails — gate the /admin analytics dashboard.
ADMIN_EMAILS=htanh9320@gmail.com
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Web (build-time, baked into the browser bundle) ──
# Must be reachable from the browser and routed to the API by nginx.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ── Translation providers ──────────────────────────────────
# The translator tries providers in TRANSLATION_PROVIDER_ORDER and falls back to
# the next when one fails (quota / auth / rate limit / network). A provider is
# ENABLED only when its API key below is set. All are OpenAI-compatible.
# Each *_API_KEY may hold MULTIPLE comma-separated keys (rotated round-robin).
TRANSLATION_PROVIDER_ORDER=gemini,groq,openrouter,openai

# OpenAI (paid). Optional OPENAI_BASE_URL for any OpenAI-compatible endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Google Gemini — free tier, https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq — free tier (the default free Cognal AI), https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — has free models, https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
